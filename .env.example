# Copy to .env and fill in. .env is gitignored — never commit real values.

# Neon Postgres — use the POOLED connection string for both app + service
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct (unpooled) URL for running migrations
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# OpenRouter (grading model). Only needed for GRADER_MODE=real.
OPENROUTER_API_KEY=sk-or-your-key-here
GRADER_MODEL=google/gemini-2.5-flash

# Grading service tuning
GRADER_MODE=stub            # stub | real
PORT=3001
WORKER_CONCURRENCY=5
RATE_LIMIT_RPS=10
GRADE_TIMEOUT_MS=30000
QUEUE_CAPACITY=200
CORS_ORIGIN=http://localhost:3000

# Stub calibration — measured from a real gemini-2.5-flash grade (~2.6s).
STUB_LATENCY_MS_MEAN=2600
STUB_LATENCY_MS_STD=500
STUB_FAILURE_RATE=0.02

# App → grading service
GRADING_SERVICE_URL=http://localhost:3001
